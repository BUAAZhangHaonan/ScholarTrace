# ScholarTrace Configuration
# Copy this file to .env and fill in your values.
# All settings can be overridden with SCHOLARTRACE_ prefix

# --- API Keys ---
SCHOLARTRACE_SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key
# Multiple S2 keys for rate-limit rotation (comma-separated)
SCHOLARTRACE_SEMANTIC_SCHOLAR_API_KEYS=key1,key2,key3
SCHOLARTRACE_OPENALEX_MAILTO=your_email@example.com
SCHOLARTRACE_CROSSREF_MAILTO=your_email@example.com

# --- BigModel GLM API (optional, for examples/glm_scholar_search.py) ---
BIGMODEL_API_KEY=your_bigmodel_api_key
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4/chat/completions

# --- Server ---
SCHOLARTRACE_API_HOST=0.0.0.0
SCHOLARTRACE_API_PORT=8000
