# ScholarTrace Configuration
# Copy this file to .env for local development only.
# For deployed services, keep secrets in /etc/scholartrace/scholartrace.env
# (or an equivalent external env file) with permissions 0600.
# All settings use the SCHOLARTRACE_ prefix.

# --- API Keys ---
SCHOLARTRACE_SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key
# Multiple S2 keys for rate-limit rotation (comma-separated)
SCHOLARTRACE_SEMANTIC_SCHOLAR_API_KEYS=key1,key2,key3
SCHOLARTRACE_OPENALEX_MAILTO=your_email@example.com
SCHOLARTRACE_CROSSREF_MAILTO=your_email@example.com

# --- BigModel GLM API (optional, for examples/glm_scholar_search.py) ---
SCHOLARTRACE_BIGMODEL_API_KEY=
SCHOLARTRACE_BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4/chat/completions
SCHOLARTRACE_BIGMODEL_MODEL=glm-5-turbo

# --- DeepXiv ---
SCHOLARTRACE_DEEPXIV_TOKENS=
SCHOLARTRACE_DEEPXIV_POOL_SIZE=3
SCHOLARTRACE_DEEPXIV_AUTO_REGISTER=false
SCHOLARTRACE_DEEPXIV_REGISTER_SDK_SECRET=

# --- Server ---
SCHOLARTRACE_API_HOST=127.0.0.1
SCHOLARTRACE_API_PORT=9000
SCHOLARTRACE_MCP_HOST=127.0.0.1
SCHOLARTRACE_MCP_PORT=8001
SCHOLARTRACE_MCP_TRANSPORT=stdio
SCHOLARTRACE_REMOTE_ACCESS_ENABLED=false
SCHOLARTRACE_ACCESS_TOKEN=

# Remote REST or SSE access requires:
# 1. SCHOLARTRACE_REMOTE_ACCESS_ENABLED=true
# 2. SCHOLARTRACE_ACCESS_TOKEN set to a strong random value
